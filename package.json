  "description": "Enterprise Database Schema Knowledge Base - Reads database metadata and stores as searchable vector knowledge for AI agents",
  "main": "dist/mcp-server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/mcp-server.js",
    "dev": "tsc && node dist/mcp-server.js",
